# =============================================================================
# Server runtime
# =============================================================================

PORT=3001
NODE_ENV=development

# How many proxies in front (express trust proxy). 1 for Vite dev or a single LB.
TRUST_PROXY=1

# Path to the SQLite file. Defaults to server/data/app.db. Override if
# persisting to a mounted volume.
# DB_PATH=./server/data/app.db


# =============================================================================
# First-boot admin seed (only used when the users table has zero admins)
# =============================================================================

DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=


# =============================================================================
# Backblaze B2 credentials
# =============================================================================

# Master partner key. Required for live-mode Partner API calls and for the
# archive-reports / object-count background jobs.
B2_MASTER_KEY_ID=
B2_MASTER_APP_KEY=

# AES-256-GCM key for encrypting sub-account application keys stored in the
# account_credentials table. Min 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
#
# WARNING: losing or rotating this value makes every stored sub-account key
# permanently unrecoverable. Back this value up SEPARATELY from the database
# (vault, secret manager, sealed envelope).
CREDENTIAL_ENCRYPTION_KEY=


# =============================================================================
# Audit log retention
# =============================================================================

# Entries older than this many days are pruned by a daily background job.
# 365 lines up with typical SOC2 / NIST 800-53 windows. Set to 0 to disable
# pruning entirely (keeps everything forever — table grows unbounded).
# AUDIT_RETENTION_DAYS=365


# =============================================================================
# Optional — admin protection
# =============================================================================

# Comma-separated emails that admins cannot modify / reset / deactivate.
# Use to protect the seed admin from being locked out by a peer admin.
# Empty = no accounts protected.
# PROTECTED_ACCOUNT_EMAIL=admin@example.com,demo@example.com


# =============================================================================
# Optional — health monitor (server/health-monitor.mjs)
# =============================================================================

# HEALTH_URL=http://localhost:3001/api/auth/me
# HEALTH_INTERVAL_MS=60000
# HEALTH_TIMEOUT_MS=10000
# HEALTH_FAIL_COUNT=3
# HEALTH_COOLDOWN_MS=60000
# HEALTH_PM2_TARGET=neocloud-api
