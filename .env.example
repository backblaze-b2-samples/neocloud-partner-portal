# Server
PORT=3001
NODE_ENV=development

# Path to the SQLite file (defaults to server/data/app.db).
# DB_PATH=./server/data/app.db

# Default admin seeded on first startup ONLY when no admin exists.
# Set both values, then start the server. Do NOT commit a real .env.
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=

# How many proxies in front (express trust proxy). 1 for Vite dev or a single LB.
TRUST_PROXY=1
